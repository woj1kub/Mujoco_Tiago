<mujoco model="tiago cup scene">
    <compiler assetdir="/home/wojkub/" />
    <include file="{basefolder}/mujoco_menagerie/pal_tiago/scene_motor.xml"/>

    <asset>
        <texture name="mug" file="{basefolder}/.mujoco/mujoco-3.9.0/model/mug/mug.png" type="2d"/>
        <material name="mug" texture="mug" specular="1" shininess="1"/>
        <mesh name="mug" file="{basefolder}/.mujoco/mujoco-3.9.0/model/mug/mug.obj" scale=".01 .01 .01"/>
        <mesh name="bottle_mesh" file="{basefolder}/object_sim/waterbottle/waterbottle.stl"/>
        <mesh name="glass_mesh" file="{basefolder}/object_sim/wineglass/wineglass.stl"/>
    </asset>


    <worldbody>
        <body name="table" pos="0.8 0 -0.5">
            <geom name="table_geom" type="box" size="0.2 0.3 0.3" rgba="0.6 0.4 0.2 1" contype="1" conaffinity="1"/>
        </body>

        <body name="cup" pos="0.8 0 0.05">
            <freejoint/>
            <!-- <inertial mass="0.1" diaginertia="0.001 0.001 0.001" pos="0 0 0"/> -->
            <geom name="cup_geom" type="mesh" mesh="mug" material="mug" euler="90 90 0" contype="1" conaffinity="1" mass="0.1"/>
        </body>

        <body name="bottle" pos="0.8 0.15 -0.1">
            <freejoint/>
            <geom type="mesh" mesh="bottle_mesh" rgba="0.1 0.6 0.1 1" contype="1" conaffinity="1" mass="0.5"/>
            <!-- <geom type="cylinder" size="0.035 0.1" rgba="1 0 0 0.5" mass="0.5"/> -->
        </body>

        <body name="glass" pos="0.8 -0.15 -0.1">
            <freejoint/>
            <geom type="mesh" mesh="glass_mesh" rgba="0.9 0.9 0.9 0.4" contype="1" conaffinity="1" mass="0.2"/>
            <!-- <geom type="cylinder" size="0.03 0.08" rgba="1 0 0 0.5" mass="0.2"/> -->
        </body>
    </worldbody>
</mujoco>

